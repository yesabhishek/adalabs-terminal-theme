  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.quoted.docstring"
      ],
      "settings": {
        "foreground": "#59636E",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#00D9FF",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#94A3B8"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#C2E88F"
      }
    },
    {
      "scope": [
        "string.regexp",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#88F0FF"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "support.constant"
      ],
      "settings": {
        "foreground": "#FFD166"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#DCE3EA"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "variable.language",
        "support.variable"
      ],
      "settings": {
        "foreground": "#A9D6FF",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "entity.name.enum",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#FF8FA3",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "entity.name.interface",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#88F0FF"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#00D9FF"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.class"
      ],
      "settings": {
        "foreground": "#D7A7FF",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "support.type.vendored.property-name.css",
        "meta.property-name",
        "variable.css"
      ],
      "settings": {
        "foreground": "#A9D6FF"
      }
    },
    {
      "scope": [
        "constant.other.color",
        "support.constant.color"
      ],
      "settings": {
        "foreground": "#FFFFFF"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF5C7A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#8996A3",
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#C2E88F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#FFFFFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#FF8FA3",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline"
      ],
      "settings": {
        "foreground": "#00D9FF",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.strikethrough"
      ],
      "settings": {
        "foreground": "#59636E",
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote.begin.markdown"
      ],
      "settings": {
        "foreground": "#7EE787",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#FFD166"
      }
    },
    {
      "scope": [
        "markup.inserted",
        "markup.inserted.git_gutter"
      ],
      "settings": {
        "foreground": "#7EE787"
      }
    },
    {
      "scope": [
        "markup.deleted",
        "markup.deleted.git_gutter"
      ],
      "settings": {
        "foreground": "#FF5C7A"
      }
    },
    {
      "scope": [
        "markup.changed",
        "markup.changed.git_gutter"
      ],
      "settings": {
        "foreground": "#FFD166"
      }
    },
    {
      "scope": [
        "meta.diff.header",
        "meta.separator"
      ],
      "settings": {
        "foreground": "#8996A3"
      }
    },
    {
      "scope": [
        "source.json support.type.property-name",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#D7A7FF"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#A9D6FF"
      }
    },
    {
      "scope": [
        "storage.type.function.arrow",
        "keyword.operator.expression",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#7AB7FF"
      }
    },
    {
      "scope": [
        "support.function.console",
        "support.class.console"
      ],
      "settings": {
        "foreground": "#FF8FA3"
      }
    },
    {
      "scope": [
        "entity.name.type.module",
        "support.type.object.module",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#7EE787"
      }
    },
    {
      "scope": [
        "meta.jsx.children",
        "text.html.derivative"
      ],
      "settings": {
        "foreground": "#E6EDF3"
      }
    },
    {
      "scope": [
        "token.info-token"
      ],
      "settings": {
        "foreground": "#7AB7FF"
      }
    },
    {
      "scope": [
        "token.warn-token"
      ],
      "settings": {
        "foreground": "#FFD166"
      }
    },
    {
      "scope": [
        "token.error-token"
      ],
      "settings": {
        "foreground": "#FF5C7A"
      }
    },
    {
      "scope": [
        "token.debug-token"
      ],
      "settings": {
        "foreground": "#D7A7FF"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#7EE787",
    "type": "#FF8FA3",
    "type.defaultLibrary": {
      "foreground": "#FF8FA3",
      "fontStyle": ""
    },
    "class": "#FF8FA3",
    "enum": "#FF8FA3",
    "interface": "#88F0FF",
    "struct": "#FF8FA3",
    "typeParameter": "#88F0FF",
    "parameter": {
      "foreground": "#A9D6FF",
      "fontStyle": ""
    },
    "variable": "#DCE3EA",
    "variable.readonly": {
      "foreground": "#FFD166",
      "fontStyle": ""
    },
    "property": "#A9D6FF",
    "enumMember": "#FFD166",
    "event": "#FFFFFF",
    "function": "#FFFFFF",
    "method": "#FFFFFF",
    "macro": "#FFFFFF",
    "keyword": {
      "foreground": "#00D9FF",
      "fontStyle": ""
    },
    "modifier": "#7AB7FF",
    "comment": {
      "foreground": "#59636E",
      "fontStyle": ""
    },
    "string": "#C2E88F",
    "number": "#FFD166",
    "regexp": "#88F0FF",
    "operator": "#94A3B8",
    "decorator": "#D7A7FF",
    "*.deprecated": {
      "foreground": "#8996A3",
      "fontStyle": "strikethrough"
    }
  }
}
