  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.quoted.docstring"
      ],
      "settings": {
        "foreground": "#6A9955",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#569CD6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#D4D4D4"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#CE9178"
      }
    },
    {
      "scope": [
        "string.regexp",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#D16969"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "support.constant"
      ],
      "settings": {
        "foreground": "#B5CEA8"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "variable.language",
        "support.variable"
      ],
      "settings": {
        "foreground": "#9CDCFE",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#DCDCAA",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "entity.name.enum",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#4EC9B0",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "entity.name.interface",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#4EC9B0"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#569CD6"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.class"
      ],
      "settings": {
        "foreground": "#9CDCFE",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "support.type.vendored.property-name.css",
        "meta.property-name",
        "variable.css"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "scope": [
        "constant.other.color",
        "support.constant.color"
      ],
      "settings": {
        "foreground": "#CE9178"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#F44747",
        "fontStyle": "italic bold"
      }
    },
    {
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#808080",
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#569CD6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#DCDCAA",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#CE9178",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline"
      ],
      "settings": {
        "foreground": "#4EC9B0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.strikethrough"
      ],
      "settings": {
        "foreground": "#6A9955",
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote.begin.markdown"
      ],
      "settings": {
        "foreground": "#6A9955",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#CE9178"
      }
    },
    {
      "scope": [
        "markup.inserted",
        "markup.inserted.git_gutter"
      ],
      "settings": {
        "foreground": "#6A9955"
      }
    },
    {
      "scope": [
        "markup.deleted",
        "markup.deleted.git_gutter"
      ],
      "settings": {
        "foreground": "#F44747"
      }
    },
    {
      "scope": [
        "markup.changed",
        "markup.changed.git_gutter"
      ],
      "settings": {
        "foreground": "#DCDCAA"
      }
    },
    {
      "scope": [
        "meta.diff.header",
        "meta.separator"
      ],
      "settings": {
        "foreground": "#8C8C8C"
      }
    },
    {
      "scope": [
        "source.json support.type.property-name",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "scope": [
        "storage.type.function.arrow",
        "keyword.operator.expression",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#C586C0"
      }
    },
    {
      "scope": [
        "support.function.console",
        "support.class.console"
      ],
      "settings": {
        "foreground": "#DCDCAA"
      }
    },
    {
      "scope": [
        "entity.name.type.module",
        "support.type.object.module",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#4EC9B0"
      }
    },
    {
      "scope": [
        "meta.jsx.children",
        "text.html.derivative"
      ],
      "settings": {
        "foreground": "#D4D4D4"
      }
    },
    {
      "scope": [
        "token.info-token"
      ],
      "settings": {
        "foreground": "#569CD6"
      }
    },
    {
      "scope": [
        "token.warn-token"
      ],
      "settings": {
        "foreground": "#DCDCAA"
      }
    },
    {
      "scope": [
        "token.error-token"
      ],
      "settings": {
        "foreground": "#F44747"
      }
    },
    {
      "scope": [
        "token.debug-token"
      ],
      "settings": {
        "foreground": "#C586C0"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#4EC9B0",
    "type": "#4EC9B0",
    "type.defaultLibrary": {
      "foreground": "#4EC9B0",
      "fontStyle": ""
    },
    "class": "#4EC9B0",
    "enum": "#4EC9B0",
    "interface": "#4EC9B0",
    "struct": "#4EC9B0",
    "typeParameter": "#4EC9B0",
    "parameter": {
      "foreground": "#9CDCFE",
      "fontStyle": "italic"
    },
    "variable": "#9CDCFE",
    "variable.readonly": {
      "foreground": "#B5CEA8",
      "fontStyle": ""
    },
    "property": "#9CDCFE",
    "enumMember": "#B5CEA8",
    "event": "#DCDCAA",
    "function": "#DCDCAA",
    "method": "#DCDCAA",
    "macro": "#DCDCAA",
    "keyword": {
      "foreground": "#569CD6",
      "fontStyle": "italic"
    },
    "modifier": "#C586C0",
    "comment": {
      "foreground": "#6A9955",
      "fontStyle": "italic"
    },
    "string": "#CE9178",
    "number": "#B5CEA8",
    "regexp": "#D16969",
    "operator": "#D4D4D4",
    "decorator": "#9CDCFE",
    "*.deprecated": {
      "foreground": "#808080",
      "fontStyle": "strikethrough"
    }
  }
}
