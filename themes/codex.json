    "event": "#6EE7B7",
    "function": "#6EE7B7",
    "method": "#6EE7B7",
    "macro": "#6EE7B7",
    "keyword": {
      "foreground": "#10A37F",
      "fontStyle": ""
    },
    "modifier": "#2DD4BF",
    "comment": {
      "foreground": "#5E6F68",
      "fontStyle": ""
    },
    "string": "#34D399",
    "number": "#A7F3D0",
    "regexp": "#99F6E4",
    "operator": "#9CA3AF",
    "decorator": "#6EE7B7",
