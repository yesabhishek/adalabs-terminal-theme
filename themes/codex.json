  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.quoted.docstring"
      ],
      "settings": {
        "foreground": "#5E6F68",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#10A37F",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#9CA3AF"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#34D399"
      }
    },
    {
      "scope": [
        "string.regexp",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#99F6E4"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "support.constant"
      ],
      "settings": {
        "foreground": "#A7F3D0"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#D1DAD6"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "variable.language",
        "support.variable"
      ],
      "settings": {
        "foreground": "#9CA3AF",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#6EE7B7",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "entity.name.enum",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#F3F7F4",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "entity.name.interface",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#99F6E4"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#10A37F"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.class"
      ],
      "settings": {
        "foreground": "#6EE7B7",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "support.type.vendored.property-name.css",
        "meta.property-name",
        "variable.css"
      ],
      "settings": {
        "foreground": "#A7F3D0"
      }
    },
    {
      "scope": [
        "constant.other.color",
        "support.constant.color"
      ],
      "settings": {
        "foreground": "#34D399"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF6B7A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#7C8B86",
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#34D399",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#F3F7F4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#A7F3D0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline"
      ],
      "settings": {
        "foreground": "#2DD4BF",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.strikethrough"
      ],
      "settings": {
        "foreground": "#5E6F68",
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote.begin.markdown"
      ],
      "settings": {
        "foreground": "#6EE7B7",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#FCD34D"
      }
    },
    {
      "scope": [
        "markup.inserted",
        "markup.inserted.git_gutter"
      ],
      "settings": {
        "foreground": "#34D399"
      }
    },
    {
      "scope": [
        "markup.deleted",
        "markup.deleted.git_gutter"
      ],
      "settings": {
        "foreground": "#FF6B7A"
      }
    },
    {
      "scope": [
        "markup.changed",
        "markup.changed.git_gutter"
      ],
      "settings": {
        "foreground": "#FCD34D"
      }
    },
    {
      "scope": [
        "meta.diff.header",
        "meta.separator"
      ],
      "settings": {
        "foreground": "#7C8B86"
      }
    },
    {
      "scope": [
        "source.json support.type.property-name",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#6EE7B7"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#A7F3D0"
      }
    },
    {
      "scope": [
        "storage.type.function.arrow",
        "keyword.operator.expression",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#2DD4BF"
      }
    },
    {
      "scope": [
        "support.function.console",
        "support.class.console"
      ],
      "settings": {
        "foreground": "#A7F3D0"
      }
    },
    {
      "scope": [
        "entity.name.type.module",
        "support.type.object.module",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#34D399"
      }
    },
    {
      "scope": [
        "meta.jsx.children",
        "text.html.derivative"
      ],
      "settings": {
        "foreground": "#D1DAD6"
      }
    },
    {
      "scope": [
        "token.info-token"
      ],
      "settings": {
        "foreground": "#60A5FA"
      }
    },
    {
      "scope": [
        "token.warn-token"
      ],
      "settings": {
        "foreground": "#FCD34D"
      }
    },
    {
      "scope": [
        "token.error-token"
      ],
      "settings": {
        "foreground": "#FF6B7A"
      }
    },
    {
      "scope": [
        "token.debug-token"
      ],
      "settings": {
        "foreground": "#C084FC"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#34D399",
    "type": "#F3F7F4",
    "type.defaultLibrary": {
      "foreground": "#F3F7F4",
      "fontStyle": ""
