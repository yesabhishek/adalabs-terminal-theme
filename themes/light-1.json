  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.quoted.docstring"
      ],
      "settings": {
        "foreground": "#667085",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#0550AE",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#57606A"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#1A7F37"
      }
    },
    {
      "scope": [
        "string.regexp",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#007C89"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "support.constant"
      ],
      "settings": {
        "foreground": "#9A6700"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#1F2937"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "variable.language",
        "support.variable"
      ],
      "settings": {
        "foreground": "#34548A",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#007C89",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "entity.name.enum",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#7E3FB2",
        "fontStyle": ""
