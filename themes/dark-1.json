    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#6CB6FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#F7F7F7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#B69CFF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline"
      ],
      "settings": {
        "foreground": "#6CB6FF",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.strikethrough"
      ],
      "settings": {
        "foreground": "#808080",
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote.begin.markdown"
      ],
      "settings": {
        "foreground": "#7DDC83",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#EBCB6B"
      }
    },
    {
      "scope": [
        "markup.inserted",
        "markup.inserted.git_gutter"
      ],
      "settings": {
        "foreground": "#7DDC83"
      }
    },
    {
      "scope": [
        "markup.deleted",
        "markup.deleted.git_gutter"
      ],
      "settings": {
        "foreground": "#FF6B7A"
      }
    },
    {
      "scope": [
        "markup.changed",
        "markup.changed.git_gutter"
      ],
      "settings": {
        "foreground": "#EBCB6B"
      }
    },
    {
      "scope": [
        "meta.diff.header",
        "meta.separator"
      ],
      "settings": {
        "foreground": "#A3A3A3"
      }
    },
    {
      "scope": [
        "source.json support.type.property-name",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#9BB8E8"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#9BB8E8"
      }
    },
    {
      "scope": [
        "storage.type.function.arrow",
        "keyword.operator.expression",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#6CB6FF"
      }
    },
    {
      "scope": [
        "support.function.console",
        "support.class.console"
      ],
      "settings": {
        "foreground": "#B69CFF"
      }
    },
    {
      "scope": [
        "entity.name.type.module",
        "support.type.object.module",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#7DDC83"
      }
    },
    {
      "scope": [
        "meta.jsx.children",
        "text.html.derivative"
      ],
      "settings": {
        "foreground": "#E7E7E7"
      }
    },
    {
      "scope": [
        "token.info-token"
      ],
      "settings": {
        "foreground": "#6CB6FF"
      }
    },
    {
      "scope": [
        "token.warn-token"
      ],
      "settings": {
        "foreground": "#EBCB6B"
      }
    },
    {
      "scope": [
        "token.error-token"
      ],
      "settings": {
        "foreground": "#FF6B7A"
      }
    },
    {
      "scope": [
        "token.debug-token"
      ],
      "settings": {
        "foreground": "#B69CFF"
      }
    }
  ],
