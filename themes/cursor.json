  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.quoted.docstring"
      ],
      "settings": {
        "foreground": "#565F89",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7AA2F7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#9ECE6A"
      }
    },
    {
      "scope": [
        "string.regexp",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#B4F9F8"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "support.constant"
      ],
      "settings": {
        "foreground": "#E0AF68"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#C0CAF5"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "variable.language",
        "support.variable"
      ],
      "settings": {
        "foreground": "#A9B1D6",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#7DCFFF",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "entity.name.enum",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#F7768E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.name.interface",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#BB9AF7"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#F7768E"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.class"
      ],
      "settings": {
        "foreground": "#BB9AF7",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "support.type.vendored.property-name.css",
        "meta.property-name",
        "variable.css"
      ],
      "settings": {
        "foreground": "#B4F9F8"
      }
    },
    {
      "scope": [
        "constant.other.color",
        "support.constant.color"
      ],
      "settings": {
        "foreground": "#E0AF68"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF5F6D",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#565F89",
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#7DCFFF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#C0CAF5",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#BB9AF7",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline"
      ],
      "settings": {
        "foreground": "#7DCFFF",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.strikethrough"
      ],
      "settings": {
        "foreground": "#565F89",
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": [
        "markup.quote",
        "punctuation.definition.quote.begin.markdown"
      ],
      "settings": {
        "foreground": "#9ECE6A",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#E0AF68"
      }
    },
    {
      "scope": [
        "markup.inserted",
        "markup.inserted.git_gutter"
      ],
      "settings": {
        "foreground": "#9ECE6A"
      }
    },
    {
      "scope": [
        "markup.deleted",
        "markup.deleted.git_gutter"
      ],
      "settings": {
        "foreground": "#FF5F6D"
      }
    },
    {
      "scope": [
        "markup.changed",
        "markup.changed.git_gutter"
      ],
      "settings": {
        "foreground": "#E0AF68"
      }
    },
    {
      "scope": [
        "meta.diff.header",
        "meta.separator"
      ],
      "settings": {
        "foreground": "#A9B1D6"
      }
    },
    {
      "scope": [
        "source.json support.type.property-name",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#BB9AF7"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#B4F9F8"
      }
    },
    {
      "scope": [
        "storage.type.function.arrow",
        "keyword.operator.expression",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#7AA2F7"
      }
    },
    {
      "scope": [
        "support.function.console",
        "support.class.console"
      ],
      "settings": {
        "foreground": "#7DCFFF"
      }
    },
    {
      "scope": [
        "entity.name.type.module",
        "support.type.object.module",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#E0AF68"
      }
    },
    {
      "scope": [
        "meta.jsx.children",
        "text.html.derivative"
      ],
      "settings": {
        "foreground": "#C0CAF5"
      }
    },
    {
      "scope": [
        "token.info-token"
      ],
      "settings": {
        "foreground": "#7AA2F7"
      }
    },
    {
      "scope": [
        "token.warn-token"
      ],
      "settings": {
        "foreground": "#E0AF68"
      }
    },
    {
      "scope": [
        "token.error-token"
      ],
      "settings": {
        "foreground": "#FF5F6D"
      }
    },
    {
      "scope": [
        "token.debug-token"
      ],
      "settings": {
        "foreground": "#BB9AF7"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#E0AF68",
    "type": "#F7768E",
    "type.defaultLibrary": {
      "foreground": "#F7768E",
      "fontStyle": "bold"
    },
    "class": "#F7768E",
    "enum": "#F7768E",
    "interface": "#BB9AF7",
    "struct": "#F7768E",
    "typeParameter": "#BB9AF7",
    "parameter": {
      "foreground": "#A9B1D6",
      "fontStyle": ""
    },
    "variable": "#C0CAF5",
    "variable.readonly": {
      "foreground": "#E0AF68",
      "fontStyle": "bold"
    },
    "property": "#B4F9F8",
    "enumMember": "#E0AF68",
    "event": "#7DCFFF",
    "function": "#7DCFFF",
    "method": "#7DCFFF",
    "macro": "#7DCFFF",
    "keyword": {
      "foreground": "#7AA2F7",
      "fontStyle": ""
    },
    "modifier": "#7AA2F7",
    "comment": {
      "foreground": "#565F89",
      "fontStyle": ""
    },
    "string": "#9ECE6A",
    "number": "#E0AF68",
    "regexp": "#B4F9F8",
    "operator": "#89DDFF",
    "decorator": "#BB9AF7",
    "*.deprecated": {
      "foreground": "#565F89",
      "fontStyle": "strikethrough"
    }
  }
}
